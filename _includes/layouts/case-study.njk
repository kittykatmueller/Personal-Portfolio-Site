<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;600&family=DM+Sans:wght@300;400;500&family=Inter:wght@400&family=Merriweather:ital,wght@0,700;0,900;1,700;1,900&family=Merriweather+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
  <script>if(localStorage.getItem('theme')==='dark')document.documentElement.setAttribute('data-theme','dark');</script>
</head>
<body>

  {% if passwordProtected %}
  <div class="pw-overlay" id="pwOverlay">
    <div class="pw-modal">
      <p class="pw-label">This page is password protected</p>
      <input type="password" class="pw-input" id="pwInput" placeholder="Enter password" />
      <button class="pw-btn" id="pwBtn">Enter</button>
      <p class="pw-error" id="pwError">Incorrect password</p>
    </div>
  </div>
  <script>
    (function() {
      const key = 'auth_{{ page.url | replace("/", "_") }}';
      const correct = '{{ password | default("Electricisthefuture") }}';
      if (sessionStorage.getItem(key) === '1') return;
      const overlay = document.getElementById('pwOverlay');
      const input = document.getElementById('pwInput');
      const btn = document.getElementById('pwBtn');
      const error = document.getElementById('pwError');
      overlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      function attempt() {
        if (input.value === correct) {
          sessionStorage.setItem(key, '1');
          overlay.style.opacity = '0';
          document.body.style.overflow = '';
          setTimeout(() => overlay.remove(), 400);
        } else {
          error.style.display = 'block';
          input.value = '';
          input.focus();
        }
      }
      btn.addEventListener('click', attempt);
      input.addEventListener('keydown', e => { if (e.key === 'Enter') attempt(); });
    })();
  </script>
  {% endif %}

  <!-- Nav -->
  <nav class="nav">
    <a href="/" class="nav-logo nav-logo--text">
      <span class="nav-logo-initials"><span class="nav-logo-k">kat</span><span class="nav-logo-m">m</span><span class="nav-logo-dot">.</span></span>
    </a>
    <div class="nav-actions">
      <a href="https://www.linkedin.com/in/kathryne-m/" target="_blank" class="nav-text-link">LinkedIn</a>
      <button class="nav-text-link nav-text-btn js-open-contact" id="nav-contact-btn">Contact</button>
      <button class="nav-theme-toggle" id="nav-theme-toggle" aria-label="Toggle dark mode">
        <svg class="theme-icon theme-icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M21 12.79A9 9 0 1111.21 3a7 7 0 109.79 9.79z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <svg class="theme-icon theme-icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>
    <button class="nav-burger" id="nav-burger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </nav>
  <div class="nav-mobile-menu" id="nav-mobile-menu">
    <a href="https://www.linkedin.com/in/kathryne-m/" target="_blank" class="nav-mobile-link">LinkedIn</a>
    <button class="nav-mobile-contact js-open-contact">Contact</button>
    <div class="nav-mobile-identity">
      <p class="nav-mobile-identity-name">Kathryne Mueller</p>
      <p class="nav-mobile-identity-title">Senior Digital Product Designer</p>
    </div>
  </div>

  <!-- Hero -->
  <div class="hero-back-wrap">
    <a href="/" class="back-link">
      <svg viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 13L5 8L10 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Back to Home
    </a>
  </div>

  {% if not hideHero %}
  <header class="hero {% if heroClass %}{{ heroClass }}{% endif %}">
    <div class="hero-content">
      <div class="hero-meta-row">
        <p class="hero-eyebrow">{{ heroEyebrow }}</p>
        {% if heroDate %}<p class="hero-date">{{ heroDate }}</p>{% endif %}
      </div>
      <h1 class="hero-heading">
        {{ heroTitle }}<br>
        <em>{{ heroTitleItalic }}</em>
      </h1>
      <p class="hero-sub">{{ heroSub }}</p>
      {% if heroStats %}
      <div class="hero-stats">
        {% for stat in heroStats %}
        <div class="hero-stat">
          <span class="hero-stat-value">{{ stat.value }}</span>
          <span class="hero-stat-label">{{ stat.label }}</span>
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    <div class="hero-visual">
      {% if heroDemo %}
        <iframe src="{{ heroDemo }}" class="hero-demo" scrolling="no" frameborder="0" allowtransparency="true"></iframe>
      {% else %}
        <img src="{{ heroImage }}" alt="{{ heroImageAlt }}" />
      {% endif %}
    </div>
  </header>

  {% if heroKeyVisual1 %}
  <div class="hero-key-visuals">
    {% if heroKeyVisual2 %}
    <div class="hero-key-visuals-row">
      <div class="hero-key-visual">
        <img src="{{ heroKeyVisual1 }}" alt="Key visual 1" />
      </div>
      <div class="hero-key-visual">
        <img src="{{ heroKeyVisual2 }}" alt="Key visual 2" />
      </div>
      {% if heroKeyVisual3 %}
      <div class="hero-key-visual">
        <img src="{{ heroKeyVisual3 }}" alt="Key visual 3" />
      </div>
      {% endif %}
      {% if heroKeyVisual4 %}
      <div class="hero-key-visual">
        <img src="{{ heroKeyVisual4 }}" alt="Key visual 4" />
      </div>
      {% endif %}
    </div>
    {% else %}
    <div class="hero-key-visual">
      <img src="{{ heroKeyVisual1 }}" alt="Key visual" />
    </div>
    {% endif %}
    {% if heroKeyVisualCaption %}<p class="img-caption" style="margin-top: 12px;">{{ heroKeyVisualCaption }}</p>{% endif %}
  </div>
  {% endif %}
  {% endif %}

  {% if heroDesktopVisual1 %}
  <div class="hero-key-visuals hero-desktop-visuals">
    <div class="hero-desktop-visuals-row">
      {% if heroDesktopVisual1 %}<img src="{{ heroDesktopVisual1 }}" alt="Desktop visual 1" />{% endif %}
      {% if heroDesktopVisual2 %}<img src="{{ heroDesktopVisual2 }}" alt="Desktop visual 2" />{% endif %}
      {% if heroDesktopVisual3 %}<img src="{{ heroDesktopVisual3 }}" alt="Desktop visual 3" />{% endif %}
    </div>
    {% if heroDesktopCaption %}<p class="img-caption" style="margin-top: 12px;">{{ heroDesktopCaption }}</p>{% endif %}
  </div>
  {% endif %}

  {% if setupFlowSection %}
  {% include "toyota-setup-flow.njk" %}
  {% endif %}

  <!-- Sticky Contents Bar -->
  {% if navItems and navItems.length %}
  <div class="cs-contents-bar" id="cs-contents-bar">
    <div class="cs-contents-inner">
      <nav class="cs-contents-nav">
        {% for item in navItems %}
        <a href="#{{ item.id }}" class="cs-contents-link">{{ item.label }}</a>
        {% endfor %}
      </nav>
    </div>
  </div>
  {% endif %}

  <!-- Case Study Body -->
  <div class="case-study">
    <main class="case-content">
      {{ content | safe }}
    </main>
  </div>

  <!-- Showcase -->
  {% if not hideShowcase %}
  <section id="key-visuals" class="showcase-section">
    {% if showcaseFramed %}
      <div class="showcase-frames-row">
        {% for img in showcaseFramed %}
          <div class="phone-frame">
            <div class="phone-frame-screen">
              <div class="phone-frame-island"></div>
              <img src="{{ img }}" alt="App screen" />
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="showcase-hero">
        {% if showcaseHero %}
          <img src="{{ showcaseHero }}" alt="Key visuals" class="showcase-img-large" />
        {% else %}
          <div class="img-placeholder showcase-img-large"></div>
        {% endif %}
      </div>
      {% if showcaseGrid1 or showcaseGrid2 %}
      <div class="showcase-grid">
        {% if showcaseGrid1 %}
          <div class="showcase-grid-cell">
            <img src="{{ showcaseGrid1 }}" alt="Key visual 1" class="showcase-grid-img" />
          </div>
        {% endif %}
        {% if showcaseGrid2 %}
          <div class="showcase-grid-cell">
            <img src="{{ showcaseGrid2 }}" alt="Key visual 2" class="showcase-grid-img showcase-grid-img--bottom" />
          </div>
        {% endif %}
      </div>
      {% endif %}
    {% endif %}
  </section>
  {% endif %}

  <!-- Next Project -->
  {% if nextProjectUrl %}
  <div class="next-project-wrap">
    <a href="{{ nextProjectUrl }}" class="next-project-card">
      <div class="next-project-text">
        <p class="next-project-eyebrow">Next Project</p>
        <h3 class="next-project-title">{{ nextProjectTitle }}</h3>
        <p class="next-project-desc">{{ nextProjectDesc }}</p>
        <span class="next-project-cta">Read Case Study →</span>
      </div>
      <div class="next-project-visual">
        <img src="{{ nextProjectImage }}" alt="{{ nextProjectTitle }}" class="next-project-img" />
      </div>
    </a>
  </div>
  {% endif %}

  <!-- Footer -->
  <footer class="site-footer">
    <div class="site-footer-top">
      <div>
        <p class="site-footer-name">Kathryne Mueller</p>
        <p class="site-footer-tagline">Senior Digital Product Designer</p>
      </div>
      <div class="site-footer-contact">
        <a href="mailto:kmuellerservices@gmail.com" class="site-footer-contact-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 8l10 6 10-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          kmuellerservices@gmail.com
        </a>
        <a href="https://www.linkedin.com/in/kathryne-m/" target="_blank" class="site-footer-contact-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>
    <div class="site-footer-bottom">
      <p class="site-footer-text">© 2026 Kathryne Mueller. All rights reserved.</p>
      <span class="site-footer-note">Vibe coded with Claude ✦</span>
    </div>
  </footer>

  <!-- Contact overlay -->
  <div class="contact-overlay" id="contact-overlay">
    <div class="contact-modal">
      <button class="contact-close" id="contact-close">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <h2 class="contact-heading">Looking forward to chat.</h2>
      <p class="contact-subtext">Drop me a message and I'll be in touch.</p>
      <form class="contact-form" id="contact-form">
        <div class="contact-field">
          <label class="contact-label" for="contact-name">Name</label>
          <input class="contact-input" type="text" id="contact-name" name="name" placeholder="Your name" />
        </div>
        <div class="contact-field">
          <label class="contact-label" for="contact-email">Email</label>
          <input class="contact-input" type="email" id="contact-email" name="email" placeholder="your@email.com" />
        </div>
        <div class="contact-field">
          <label class="contact-label" for="contact-message">Message</label>
          <textarea class="contact-input contact-textarea" id="contact-message" name="message" placeholder="Tell me about your project..."></textarea>
        </div>
        <button type="submit" class="contact-submit">Send Message</button>
      </form>
      <div class="contact-divider"></div>
      <div class="contact-email-section">
        <p class="contact-email-label">Or reach me directly</p>
        <button class="contact-email-btn" id="contact-email-btn">
          kmuellerservices@gmail.com
          <svg class="contact-copy-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="9" y="9" width="13" height="13" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke="currentColor" stroke-width="1.5"/></svg>
        </button>
        <span class="contact-copied" id="contact-copied">Copied!</span>
      </div>
    </div>
  </div>

  <script src="/js/theme.js"></script>
  <script src="/js/case-study.js" defer></script>
  <script src="/js/nav.js" defer></script>
  <script src="/js/contact.js" defer></script>

</body>
</html>
